# Production - Turso
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Local dev: không cần config gì, tự dùng SQLite

# AI Configuration
# AI_PROVIDER: 'openai' hoặc 'deepseek' (mặc định: openai)
AI_PROVIDER=openai
# API key cho OpenAI
OPENAI_API_KEY=sk-your-openai-key
# API key cho Deepseek (dùng nếu AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
# Giới hạn request AI mỗi ngày mỗi player (mặc định: 50)
AI_DAILY_LIMIT=50
# Tên model sử dụng (mặc định: gpt-4o-mini cho openai, deepseek-chat cho deepseek)
AI_MODEL=
